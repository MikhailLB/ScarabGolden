<?xml version="1.0" encoding="utf-8"?>
<!--
    Pre-Android-12 splash background.  Kept in sync with the
    Android 12+ splash theme (@color/launch_bg + centred art)
    so users on API 30 see the same visual as users on API 31+.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/launch_bg"/>
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/launcher_icon"/>
    </item>
</layer-list>
