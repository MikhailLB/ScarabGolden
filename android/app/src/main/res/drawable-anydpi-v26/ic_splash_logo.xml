<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ splash-screen animated icon.

    Android 12+ SILENTLY refuses any splash icon that is not an
    <adaptive-icon>.  A flat @mipmap/launcher_icon PNG will just
    make the OS fall back on the app icon (unclipped 192dp),
    which then reads as visibly cropped on the launcher circle.

    Mirror the launcher-icon composition exactly (same inset,
    same background colour) so the icon that flies into the
    splash lines up pixel-for-pixel with the icon the user just
    tapped on the launcher.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/launch_bg"/>
    <foreground>
        <inset
            android:drawable="@drawable/sg_pharaoh_art"
            android:inset="14%"/>
    </foreground>
</adaptive-icon>
